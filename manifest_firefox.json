{
  "manifest_version": 3,
  "name": "iCloud Album Downloader",
  "version": "1.1.1",
  "description": "Download entire shared iCloud photo albums — see item counts and download everything in one click.",
  "permissions": [
    "downloads",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.icloud.com/*",
    "https://*.icloud-content.com/*",
    "https://*.workers.dev/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "iCloud Album Downloader"
  },
  "background": {
    "scripts": ["config.js", "reporting.js", "background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "icloud-album-downloader-pub@extension",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "public": false
      }
    }
  }
}
